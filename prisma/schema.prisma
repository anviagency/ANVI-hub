// ANVI Recruitment OS — data model (spec §10), implemented on PostgreSQL via Prisma.
// No Supabase: plain Postgres + Prisma migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// CLIENTS
// ---------------------------------------------------------------------------
model Client {
  id             String   @id @default(cuid())
  name           String
  company        String?
  initials       String?
  country        String?
  tz             String?
  whatsappNumber String?  @map("whatsapp_number")
  email          String?
  portalSlug     String   @unique @map("portal_slug")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  jobs        Job[]
  submissions Submission[]
  events      CandidateEvent[]
  placements  Placement[]
  offers      Offer[]
  shareLinks  ShareLink[]
  clientMessages ClientMessage[]
  users       User[]

  @@map("client")
}

// ---------------------------------------------------------------------------
// AUTH: users, roles, sessions, audit (Mission 3.5 P1)
// ---------------------------------------------------------------------------
enum Role {
  admin
  recruiter
  client
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         Role     @default(recruiter)
  // For client-role users: the client account they can see.
  clientId     String?  @map("client_id")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  client   Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  sessions Session[]
  audits   AuditLog[]

  @@index([role])
  @@map("user")
}

model Session {
  id         String   @id @default(cuid())
  tokenHash  String   @unique @map("token_hash")
  userId     String   @map("user_id")
  expiresAt  DateTime @map("expires_at")
  ip         String?
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("session")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  actorType String   @map("actor_type") // user | client | system
  action    String
  entity    String?
  entityId  String?  @map("entity_id")
  meta      Json     @default("{}")
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([entity, entityId])
  @@map("audit_log")
}

// ---------------------------------------------------------------------------
// BACKGROUND JOB QUEUE (Mission 3.5 P4) — Postgres-backed, no extra infra.
// ---------------------------------------------------------------------------
enum TaskStatus {
  pending
  running
  done
  failed
}

model BackgroundJob {
  id          String     @id @default(cuid())
  type        String
  payload     Json       @default("{}")
  status      TaskStatus @default(pending)
  attempts    Int        @default(0)
  maxAttempts Int        @default(5) @map("max_attempts")
  runAt       DateTime   @default(now()) @map("run_at")
  lockedAt    DateTime?  @map("locked_at")
  lastError   String?    @map("last_error")
  result      Json?
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@index([status, runAt])
  @@map("background_job")
}

// ---------------------------------------------------------------------------
// SKILLS (canonical + synonyms, plus optional release year for anomaly checks)
// ---------------------------------------------------------------------------
model Skill {
  id            String   @id @default(cuid())
  canonicalName String   @unique @map("canonical_name")
  synonyms      String[] @default([])
  // Year the technology was first publicly released. Used by the anomaly
  // engine to flag impossible tenure (skill_years > current_year - release_year).
  releaseYear   Int?     @map("release_year")

  jobSkills       JobSkill[]
  candidateSkills CandidateSkill[]

  @@map("skill")
}

// ---------------------------------------------------------------------------
// JOBS (parsed from chat)
// ---------------------------------------------------------------------------
enum JobStatus {
  open
  paused
  filled
}

model Job {
  id                 String    @id @default(cuid())
  clientId           String?   @map("client_id")
  title              String
  seniority          String?
  budgetMin          Float?    @map("budget_min")
  budgetMax          Float?    @map("budget_max")
  budgetUnit         String?   @map("budget_unit") // e.g. "usd_hour"
  englishLevel       String?   @map("english_level")
  experienceYearsMin Int?      @map("experience_years_min")
  // Conversational-intake fields (Mission 7.1) shown on the Job Workspace.
  workMode           String?   @map("work_mode")        // remote | hybrid | onsite
  employmentType     String?   @map("employment_type")  // full_time | part_time | contract
  descriptionRaw     String?   @map("description_raw")
  status             JobStatus @default(open)
  archivedAt         DateTime? @map("archived_at")
  deletedAt          DateTime? @map("deleted_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  client      Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  skills      JobSkill[]
  analyses    CandidateAnalysis[]
  events      CandidateEvent[]
  interviews  Interview[]
  submissions Submission[]
  placements  Placement[]
  offers      Offer[]
  pipelines   Pipeline[]
  notes       Note[]
  shareLinks  ShareLink[]
  candidateAccess CandidateAccess[]
  clientMessages  ClientMessage[]

  @@index([clientId])
  @@map("job")
}

model JobSkill {
  id       String  @id @default(cuid())
  jobId    String  @map("job_id")
  skillId  String  @map("skill_id")
  required Boolean @default(true)
  minYears Int?    @map("min_years")

  job   Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([jobId, skillId])
  @@map("job_skill")
}

// ---------------------------------------------------------------------------
// CANDIDATES
// ---------------------------------------------------------------------------
enum Availability {
  available
  on_hold
  placed
}

model Candidate {
  id                String       @id @default(cuid())
  fullName          String       @map("full_name")
  title             String?
  email             String?
  phone             String?
  location          String?
  country           String?
  flag              String?
  availability      Availability @default(available)
  availabilityNote  String?      @map("availability_note") // e.g. "2 weeks", "Immediate"
  englishLevel      String?      @map("english_level")
  totalYears        Float?       @map("total_years")
  // Earliest career start year — anchors the "career length" anomaly checks.
  careerStartYear   Int?         @map("career_start_year")
  salaryExpectation Float?       @map("salary_expectation") // internal cost, $/hr
  clientRate        Float?       @map("client_rate")        // shown to client, $/hr
  cvUrl             String?      @map("cv_url")
  // Title as it appears on LinkedIn — used for CV-vs-LinkedIn conflict checks.
  linkedinUrl       String?      @map("linkedin_url")
  linkedinTitle     String?      @map("linkedin_title")
  aiSummary         String?      @map("ai_summary")
  source            String?
  // Raw CV text (pasted/uploaded) — basis for AI extraction (Mission 5.1 P2).
  cvText            String?      @map("cv_text")
  lastContactedAt   DateTime?    @map("last_contacted_at")
  lastScreenedAt    DateTime?    @map("last_screened_at")
  // When availability was last explicitly confirmed (Mission 5.1 P5).
  availabilityConfirmedAt DateTime? @map("availability_confirmed_at")
  // Soft-delete / archive (Mission 5.1 P1 — nothing disappears permanently).
  archivedAt        DateTime?    @map("archived_at")
  deletedAt         DateTime?    @map("deleted_at")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  // Identity used for import dedupe (email preferred, else name+country).
  dedupeKey         String?      @unique @map("dedupe_key")
  importBatchId     String?      @map("import_batch_id")

  skills       CandidateSkill[]
  intelligence CandidateIntelligence?
  employments  Employment[]
  analyses     CandidateAnalysis[]
  events      CandidateEvent[]
  interviews  Interview[]
  submissions Submission[]
  placements  Placement[]
  offers      Offer[]
  pipelines   Pipeline[]
  notes       Note[]
  shares      ShareLinkCandidate[]
  accessLinks    CandidateAccess[]
  clientMessages ClientMessage[]
  importBatch ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  @@index([availability])
  @@index([updatedAt])
  @@index([country])
  @@map("candidate")
}

// ---------------------------------------------------------------------------
// CANDIDATE INTELLIGENCE (Mission 10 Phase 2) — a structured intelligence object
// inferred from the CV (AI-primary, deterministic fallback). Layered ON TOP of
// the factual skills/employments; never replaces them. JSON arrays hold typed
// lists; scalars are kept for fast filtering. `confidence`/`raw` for provenance.
// ---------------------------------------------------------------------------
model CandidateIntelligence {
  candidateId String   @id @map("candidate_id")
  // Technical
  languages       Json @default("[]")
  frameworks      Json @default("[]")
  databases       Json @default("[]")
  cloudProviders  Json @default("[]") @map("cloud_providers")
  devopsTools     Json @default("[]") @map("devops_tools")
  aimlTools       Json @default("[]") @map("aiml_tools")
  architectureExp Json @default("[]") @map("architecture_exp")
  // Business
  industries    Json    @default("[]")
  domains       Json    @default("[]")
  companySizes  Json    @default("[]") @map("company_sizes")
  startupExp    Boolean @default(false) @map("startup_exp")
  enterpriseExp Boolean @default(false) @map("enterprise_exp")
  consultingExp Boolean @default(false) @map("consulting_exp")
  // Leadership
  teamLeadership  Boolean @default(false) @map("team_leadership")
  managementYears Float?  @map("management_years")
  hiringExp       Boolean @default(false) @map("hiring_exp")
  mentoringExp    Boolean @default(false) @map("mentoring_exp")
  maxTeamSize     Int?    @map("max_team_size")
  // Communication
  spokenLanguages         Json @default("[]") @map("spoken_languages")
  writtenLanguages        Json @default("[]") @map("written_languages")
  englishConfidence       Int? @map("english_confidence")
  communicationConfidence Int? @map("communication_confidence")
  // Geography
  city              String?
  timezone          String?
  relocationWilling Boolean? @map("relocation_willing")
  remoteExperience  Boolean  @default(false) @map("remote_experience")
  // Employment
  avgTenureMonths Int?     @map("avg_tenure_months")
  stabilityScore  Int?     @map("stability_score")
  jobHopping      Boolean  @default(false) @map("job_hopping")
  employmentGaps  Json     @default("[]") @map("employment_gaps")
  // Education
  education      Json    @default("[]")
  certifications Json    @default("[]")
  militaryExp    Boolean @default(false) @map("military_exp")
  // Provenance
  modelVersion String?  @map("model_version")
  confidence   Int?
  source       String   @default("deterministic") // ai | deterministic | hybrid
  raw          Json     @default("{}")
  generatedAt  DateTime @default(now()) @map("generated_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_intelligence")
}

model CandidateSkill {
  id          String  @id @default(cuid())
  candidateId String  @map("candidate_id")
  skillId     String  @map("skill_id")
  years       Float   @default(0)

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  skill     Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([candidateId, skillId])
  @@index([skillId])
  @@map("candidate_skill")
}

// Employment history — backs the date-overlap / gap / tenure anomaly rules.
model Employment {
  id           String    @id @default(cuid())
  candidateId  String    @map("candidate_id")
  company      String
  title        String?
  fullTime     Boolean   @default(true) @map("full_time")
  startDate    DateTime  @map("start_date")
  endDate      DateTime? @map("end_date") // null = current
  createdAt    DateTime  @default(now()) @map("created_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@map("employment")
}

// ---------------------------------------------------------------------------
// AI INTELLIGENCE (cached per candidate per job)
// ---------------------------------------------------------------------------
enum Recommendation {
  strong
  possible
  weak
}

model CandidateAnalysis {
  id           String         @id @default(cuid())
  candidateId  String         @map("candidate_id")
  jobId        String         @map("job_id")
  matchScore   Float          @map("match_score")
  recommendation Recommendation @default(possible)
  strengths    Json           @default("[]") // [{text, evidence}]
  risks        Json           @default("[]") // [{text, severity}]
  anomalies    Json           @default("[]") // [{text, rule, severity}]
  modelVersion String?        @map("model_version")
  analyzedAt   DateTime       @default(now()) @map("analyzed_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([candidateId, jobId])
  @@map("candidate_analysis")
}

// ---------------------------------------------------------------------------
// TIMELINE / EVENTS
// ---------------------------------------------------------------------------
enum EventType {
  created
  updated
  contacted
  screened
  submitted
  interview_scheduled
  passed
  failed
  placed
  imported
  stage_changed
  note_added
  communication
  shared
  client_approved
  client_rejected
  interview_requested
  offer_extended
  offer_accepted
  offer_declined
  offer_withdrawn
  availability_confirmed
  availability_declined
  candidate_confirmed_interview
  candidate_reschedule_requested
  client_message
}

enum Actor {
  recruiter
  system
  client
  candidate
}

model CandidateEvent {
  id          String    @id @default(cuid())
  candidateId String    @map("candidate_id")
  jobId       String?   @map("job_id")
  clientId    String?   @map("client_id")
  type        EventType
  meta        Json      @default("{}")
  actor       Actor     @default(recruiter)
  createdAt   DateTime  @default(now()) @map("created_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job       Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([candidateId])
  @@map("candidate_event")
}

// ---------------------------------------------------------------------------
// INTERVIEWS (Timeless / timeOS)
// ---------------------------------------------------------------------------
model Interview {
  id               String    @id @default(cuid())
  candidateId      String    @map("candidate_id")
  jobId            String?   @map("job_id")
  timelessMeetingId String?  @unique @map("timeless_meeting_id")
  // Tag ANVI generates at scheduling time so an inbound meeting can be matched
  // back to this interview (Mission 4 — MeetingIntelligenceProvider).
  meetingTag       String?   @unique @map("meeting_tag")
  provider         String?   // e.g. "timeos", "mock"
  recordingUrl     String?   @map("recording_url")
  transcript       String?
  summary          String?
  actionItems      Json      @default("[]") @map("action_items")
  participants     Json      @default("[]")
  meetingTime      DateTime? @map("meeting_time")
  scheduledFor     DateTime? @map("scheduled_for")
  // Real scheduling fields (Mission 5.1 P3).
  timezone         String?
  durationMins     Int?      @map("duration_mins")
  meetingUrl       String?   @map("meeting_url")
  meetingProvider  String?   @map("meeting_provider") // google_meet | zoom | teams
  // True only when the meeting URL is real: recruiter-provided or booked by a
  // configured provider. Auto-shaped placeholder links are NEVER provisioned and
  // are never shown to clients (Mission 8 Phase 1 — no fake links).
  meetingProvisioned Boolean @default(false) @map("meeting_provisioned")
  // Recruiter-proposed time options (ISO strings) the client/candidate picks from.
  proposedSlots    Json      @default("[]") @map("proposed_slots")
  // Candidate's own response to the invite (Mission 8 Phase 3).
  // none | confirmed | declined | reschedule_requested
  candidateStatus  String    @default("none") @map("candidate_status")
  candidateMessage String?   @map("candidate_message")
  candidateRespondedAt DateTime? @map("candidate_responded_at")
  // proposed | scheduled | rescheduled | cancelled | completed
  status           String    @default("scheduled")
  cancelledAt      DateTime? @map("cancelled_at")
  cancelReason     String?   @map("cancel_reason")
  completedAt      DateTime? @map("completed_at")
  outcome          String?
  // none | scheduled | summary_ready | failed (TimeOS webhook lifecycle)
  webhookStatus    String    @default("none") @map("webhook_status")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job       Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([candidateId])
  @@map("interview")
}

// ---------------------------------------------------------------------------
// CLIENT SUBMISSIONS
// ---------------------------------------------------------------------------
enum ClientStatus {
  pending
  approved
  rejected
}

model Submission {
  id             String       @id @default(cuid())
  clientId       String       @map("client_id")
  jobId          String       @map("job_id")
  candidateId    String       @map("candidate_id")
  clientStatus   ClientStatus @default(pending) @map("client_status")
  clientFeedback String?      @map("client_feedback")
  submittedAt    DateTime     @default(now()) @map("submitted_at")

  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([jobId, candidateId])
  @@map("submission")
}

// ---------------------------------------------------------------------------
// OFFERS (close the funnel: approval → offer → placement → start date, spec §8)
// ---------------------------------------------------------------------------
enum OfferStatus {
  draft
  sent
  accepted
  declined
  withdrawn
}

model Offer {
  id            String      @id @default(cuid())
  candidateId   String      @map("candidate_id")
  jobId         String      @map("job_id")
  clientId      String      @map("client_id")
  status        OfferStatus @default(sent)
  // clientRate is the price shown to the client; salary is the internal cost.
  // Both are snapshotted at offer time so later candidate edits don't rewrite history.
  clientRate    Float?      @map("client_rate")
  salary        Float?
  currency      String      @default("usd")
  startDate     DateTime?   @map("start_date")
  expiresAt     DateTime?   @map("expires_at")
  notes         String?
  declineReason String?     @map("decline_reason")
  createdBy     String?     @map("created_by")
  sentAt        DateTime?   @map("sent_at")
  respondedAt   DateTime?   @map("responded_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  candidate Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job       Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  client    Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  placement Placement?

  @@index([candidateId])
  @@index([jobId])
  @@index([clientId])
  @@index([status])
  @@map("offer")
}

// ---------------------------------------------------------------------------
// PHASE 2: ongoing workforce
// ---------------------------------------------------------------------------
model Placement {
  id               String    @id @default(cuid())
  clientId         String    @map("client_id")
  candidateId      String    @map("candidate_id")
  jobId            String?   @map("job_id")
  offerId          String?   @unique @map("offer_id")
  title            String?
  // clientRate snapshot for the placed worker (price billed to the client).
  clientRate       Float?    @map("client_rate")
  startDate        DateTime? @map("start_date")
  endDate          DateTime? @map("end_date")
  status           String    @default("active") // active | ended | paused
  // pending | in_progress | complete — drives the onboarding checklist.
  onboardingStatus String    @default("pending") @map("onboarding_status")
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job       Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  offer     Offer?    @relation(fields: [offerId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([status])
  @@map("placement")
}

// ---------------------------------------------------------------------------
// CANDIDATE MICRO-SURFACE (Mission 8 Phase 3) — a secure, tokenized link that
// lets a candidate self-confirm availability and respond to an interview invite
// with no login. Token-authorized only; rate-limited like share links.
// ---------------------------------------------------------------------------
model CandidateAccess {
  id           String    @id @default(cuid())
  token        String    @unique
  candidateId  String    @map("candidate_id")
  jobId        String?   @map("job_id")
  expiresAt    DateTime? @map("expires_at")
  lastViewedAt DateTime? @map("last_viewed_at")
  createdById  String?   @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job       Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([candidateId])
  @@map("candidate_access")
}

// ---------------------------------------------------------------------------
// CLIENT MESSAGES (Mission 8 Phase 4) — minimal client free-text so the workflow
// never dead-ends ("ask a question" / "request another time"). NOT a full inbox:
// each message surfaces as a recruiter notification + timeline event.
// ---------------------------------------------------------------------------
model ClientMessage {
  id          String    @id @default(cuid())
  clientId    String?   @map("client_id")
  jobId       String    @map("job_id")
  candidateId String?   @map("candidate_id")
  kind        String    @default("question") // question | reschedule_request
  body        String
  via         String    @default("share_link") // share_link | whatsapp
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  client    Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  job       Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)

  @@index([jobId])
  @@index([resolvedAt])
  @@map("client_message")
}

// ---------------------------------------------------------------------------
// RECRUITING PIPELINE (per candidate per job)
// ---------------------------------------------------------------------------
enum PipelineStage {
  new
  screened
  sent_to_client
  interview
  approved
  offer
  rejected
  hired
}

model Pipeline {
  id          String        @id @default(cuid())
  candidateId String        @map("candidate_id")
  jobId       String        @map("job_id")
  stage       PipelineStage @default(new)
  // Denormalized for fast filtering/sorting on the board.
  enteredStageAt DateTime   @default(now()) @map("entered_stage_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([candidateId, jobId])
  @@index([jobId, stage])
  @@map("pipeline")
}

// ---------------------------------------------------------------------------
// NOTES & COMMUNICATION HISTORY
// ---------------------------------------------------------------------------
enum NoteKind {
  note
  call
  email
  telegram
  whatsapp
  interview
}

model Note {
  id          String   @id @default(cuid())
  candidateId String   @map("candidate_id")
  jobId       String?  @map("job_id")
  kind        NoteKind @default(note)
  body        String
  // Internal notes are never exposed on a client share link unless that link
  // explicitly opts in (ShareLinkCandidate.shareNotes).
  internal    Boolean  @default(true)
  author      String?
  editedAt    DateTime? @map("edited_at")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job       Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([candidateId])
  @@map("note")
}

// ---------------------------------------------------------------------------
// CLIENT SHARE LINKS (secure, scoped, client-facing)
// ---------------------------------------------------------------------------
model ShareLink {
  id        String    @id @default(cuid())
  token     String    @unique
  jobId     String    @map("job_id")
  clientId  String?   @map("client_id")
  label     String?
  revoked   Boolean   @default(false)
  revokedAt DateTime? @map("revoked_at")
  revokedBy String?   @map("revoked_by")
  createdById String? @map("created_by")
  expiresAt DateTime? @map("expires_at")
  lastViewedAt DateTime? @map("last_viewed_at")
  viewCount Int       @default(0) @map("view_count")
  createdAt DateTime  @default(now()) @map("created_at")

  job        Job                  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  client     Client?              @relation(fields: [clientId], references: [id], onDelete: SetNull)
  candidates ShareLinkCandidate[]

  @@index([jobId])
  @@map("share_link")
}

model ShareLinkCandidate {
  id          String  @id @default(cuid())
  shareLinkId String  @map("share_link_id")
  candidateId String  @map("candidate_id")
  // When true, internal notes for this candidate are visible on the link.
  shareNotes  Boolean @default(false) @map("share_notes")

  shareLink ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([shareLinkId, candidateId])
  @@map("share_link_candidate")
}

// ---------------------------------------------------------------------------
// NOTIFICATIONS (Telegram sync + recruiter notifications)
// ---------------------------------------------------------------------------
enum NotificationChannel {
  telegram
  recruiter
  email
}

enum NotificationStatus {
  queued
  sent
  failed
  skipped
}

model Notification {
  id          String              @id @default(cuid())
  channel     NotificationChannel
  status      NotificationStatus  @default(queued)
  title       String
  body        String
  jobId       String?             @map("job_id")
  candidateId String?             @map("candidate_id")
  externalRef String?             @map("external_ref")
  error       String?
  createdAt   DateTime            @default(now()) @map("created_at")

  @@index([channel, status])
  @@map("notification")
}

// ---------------------------------------------------------------------------
// IMPORT BATCHES (Excel/CSV ingestion audit)
// ---------------------------------------------------------------------------
model ImportBatch {
  id        String   @id @default(cuid())
  filename  String?
  source    String?
  total     Int      @default(0)
  created   Int      @default(0)
  updated   Int      @default(0)
  skipped   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  candidates Candidate[]

  @@map("import_batch")
}

// ---------------------------------------------------------------------------
// WHATSAPP (Mission 4) — every outbound + inbound message is persisted.
// ---------------------------------------------------------------------------
enum WaDirection {
  outbound
  inbound
}

enum WaKind {
  template
  interactive
  text
}

enum WaStatus {
  queued
  sent
  delivered
  failed
  skipped
  received
}

model WaMessage {
  id          String      @id @default(cuid())
  direction   WaDirection
  kind        WaKind
  status      WaStatus    @default(queued)
  toNumber    String?     @map("to_number")
  fromNumber  String?     @map("from_number")
  clientId    String?     @map("client_id")
  candidateId String?     @map("candidate_id")
  jobId       String?     @map("job_id")
  templateName String?    @map("template_name")
  event       String?     // semantic event: candidate_submitted, screening_completed, reminder…
  body        String?
  payload     Json        @default("{}")
  externalId  String?     @map("external_id") // provider message id
  error       String?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([candidateId])
  @@index([status])
  @@map("wa_message")
}

// ---------------------------------------------------------------------------
// WEBHOOK IDEMPOTENCY (Mission 4) — dedupe inbound WhatsApp + TimeOS events.
// ---------------------------------------------------------------------------
model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String   // whatsapp | timeos
  externalId  String   @map("external_id")
  type        String?
  status      String   @default("received") // received | processed | failed | duplicate
  payload     Json     @default("{}")
  error       String?
  createdAt   DateTime @default(now()) @map("created_at")
  processedAt DateTime? @map("processed_at")

  @@unique([provider, externalId])
  @@index([provider, status])
  @@map("webhook_event")
}
