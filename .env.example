# --- Database (PostgreSQL, no Supabase) ---
# Matches docker-compose.yml (host port 5434).
DATABASE_URL="postgresql://anvi:anvi@localhost:5434/anvi?schema=public"

# --- Anthropic (optional) ---
# When set, ANVI uses Claude for job parsing, intent routing, and analysis narrative.
# When unset, ANVI falls back to the built-in deterministic engine (still fully functional).
ANTHROPIC_API_KEY=""
# Models — sonnet for routing/parse, opus-class for deep analysis narrative.
ANVI_MODEL_FAST="claude-sonnet-4-6"
ANVI_MODEL_DEEP="claude-opus-4-8"

# --- Telegram sync (optional) ---
# When both are set, pipeline/status changes are pushed to the Telegram group.
# When unset, notifications are still persisted (status="skipped") and the app works.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
