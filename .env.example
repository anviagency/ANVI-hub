# --- Database (PostgreSQL, no Supabase) ---
# Matches docker-compose.yml (host port 5434).
DATABASE_URL="postgresql://anvi:anvi@localhost:5434/anvi?schema=public"

# --- Anthropic (optional) ---
# When set, ANVI uses Claude for job parsing, intent routing, and analysis narrative.
# When unset, ANVI falls back to the built-in deterministic engine (still fully functional).
ANTHROPIC_API_KEY=""
# Models — sonnet for routing/parse, opus-class for deep analysis narrative.
ANVI_MODEL_FAST="claude-sonnet-4-6"
ANVI_MODEL_DEEP="claude-opus-4-8"

# --- Telegram sync (optional) ---
# When both are set, pipeline/status changes are pushed to the Telegram group.
# When unset, notifications are still persisted (status="skipped") and the app works.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# --- WhatsApp (optional, Meta Business API / BSP) ---
# When ACCESS_TOKEN + PHONE_NUMBER_ID are set, the real Meta provider is used;
# otherwise a mock provider simulates sends (messages still persisted). No keys required.
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN="anvi-dev-verify"

# --- TimeOS / Timeless (optional, meeting intelligence) ---
# When TIMEOS_API_KEY is set, the real provider is used; otherwise a mock provider.
TIMEOS_API_KEY=""
TIMEOS_API_BASE="https://api.timeless.day"

# --- Email (optional, Resend) — reminders go "WhatsApp + email if available". ---
RESEND_API_KEY=""
EMAIL_FROM="ANVI <noreply@anvi.example>"
